# ─── Base de données ───────────────────────────────────────────────────────────
# Connexion PostgreSQL
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:password@localhost:5432/chad_homies"

# ─── Authentification ──────────────────────────────────────────────────────────
# Clé secrète pour signer les sessions JWT
# Générer avec : node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
AUTH_SECRET="remplace-par-une-cle-secrete-de-32-chars-minimum"

# URL publique du site (sans slash final)
# En production : https://ton-domaine.com
APP_URL="http://localhost:3000"
NEXTAUTH_URL="http://localhost:3000"

# ─── Discord OAuth ─────────────────────────────────────────────────────────────
# 1. Va sur https://discord.com/developers/applications
# 2. Crée une nouvelle application
# 3. Onglet OAuth2 > ajoute le Redirect URI :
#    https://ton-domaine.com/api/auth/discord/callback
# 4. Copie le Client ID et le Client Secret ci-dessous
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# ─── Email (optionnel) ─────────────────────────────────────────────────────────
EMAIL_SERVER_HOST="smtp.gmail.com"
EMAIL_SERVER_PORT="587"
EMAIL_SERVER_USER=""
EMAIL_SERVER_PASSWORD=""
EMAIL_FROM="CHAD Homies <no-reply@chadhomies.local>"

# ─── Upload fichiers (optionnel — UploadThing) ────────────────────────────────
# https://uploadthing.com
UPLOADTHING_SECRET=""
UPLOADTHING_APP_ID=""

# ─── Environnement ─────────────────────────────────────────────────────────────
NODE_ENV="production"
